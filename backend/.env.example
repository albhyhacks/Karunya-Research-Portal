# Database Configuration
# format: postgresql+asyncpg://user:password@localhost:5432/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/research_portal

# Scopus API Configuration
# Get your API key from the Elsevier developer portal (https://dev.elsevier.com/)
SCOPUS_API_KEY=your_scopus_api_key_here
# Your institution's affiliation ID from Scopus
SCOPUS_AFFILIATION_ID=your_affiliation_id_here

# Task Queue Configuration
# Redis URL for Celery broker/backend
REDIS_URL=redis://localhost:6379/0

# Security
# Generate a secure secret key for JWT/Sessions
SECRET_KEY=your_super_secret_key_here
